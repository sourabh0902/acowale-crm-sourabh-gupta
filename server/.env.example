PORT=
MONGODB_URI=use the standard-string instead of +srv
JWT_SECRET=your-jwt-secret-min-32-chars-use-crypto-randomBytes
JWT_EXPIRES_IN=
CORS_ORIGIN=
NODE_ENV=development

# --- Seed script (only used by scripts/seed.ts, required by that script) ---
# Set these before running `npm run seed`. The seed script will fail loudly if missing.
# In production, override the password to something you'll actually share with reviewers.
SEED_ADMIN_EMAIL=admin@acowale.com
SEED_ADMIN_PASSWORD=change-this-before-seeding
